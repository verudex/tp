@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class AddressBook
Class ModelManager
Class UserPrefs

Class UniquePatientList
Class Patient
Class Address
Class Email
Class Name
Class Nric
Class Phone
Class Sex
Class DateOfBirth
Class Appointment
Class "{abstract}\nTag" as Tag
Class Allergy
Class Condition

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyAddressBook
ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

AddressBook *--> "1" UniquePatientList
UniquePatientList --> "~* all" Patient
Patient *--> "1" Name
Patient *--> "1" Nric
Patient *--> "1" Phone
Patient *--> "1" Sex
Patient *--> "1" DateOfBirth
Patient *--> "1" Email
Patient *--> "1" Address
Patient *--> "0..1" Appointment
Patient *--> "*" Tag

Allergy -up-|> Tag
Condition -up-|> Tag

Patient -[hidden]up--> I
UniquePatientList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Nric
Nric -[hidden]right-> Sex
Sex -[hidden]right-> DateOfBirth
DateOfBirth -[hidden]right-> Address
Address -[hidden]right-> Email
Email -[hidden]right-> Appointment

ModelManager --> "~* filtered" Patient
@enduml
