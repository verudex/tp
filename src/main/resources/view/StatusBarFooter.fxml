<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<GridPane styleClass="status-bar" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10" percentWidth="50.0" halignment="LEFT" />
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10" percentWidth="50.0" halignment="RIGHT" />
  </columnConstraints>
  <rowConstraints>
    <RowConstraints minHeight="10" vgrow="SOMETIMES" />
  </rowConstraints>

  <Label fx:id="totalPatientCount" GridPane.columnIndex="0" />

  <Label fx:id="saveLocationStatus" GridPane.columnIndex="1" />
</GridPane>
